generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////////

enum IndustryType {
  RESTAURANT
  RETAIL
  MANUFACTURING
  CAFE
  OTHER
}

enum StoreStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  DISCONTINUED
}

//////////////////////////////////////////////////////////
// ORGANIZATION
//////////////////////////////////////////////////////////

model Organization {
  id       String       @id @default(uuid())
  name     String
  industry IndustryType
  email    String?
  phone    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores    Store[]
  products  Product[]
  snapshots InventorySnapshot[]
}

//////////////////////////////////////////////////////////
// STORE
//////////////////////////////////////////////////////////

model Store {
  id String @id @default(uuid())

  organizationId String

  name    String
  address String?
  manager String?

  status StoreStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

//////////////////////////////////////////////////////////
// PRODUCT
//////////////////////////////////////////////////////////

model Product {
  id String @id @default(uuid())

  organizationId String

  sku      String
  name     String
  category String?
  unit     String?

  costPrice    Float
  sellingPrice Float

  barcode String?

  status ProductStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, sku])
  @@index([organizationId])
}

//////////////////////////////////////////////////////////
// INVENTORY SNAPSHOT
//////////////////////////////////////////////////////////

model InventorySnapshot {
  id String @id @default(uuid())

  organizationId String

  uploadedFileName String

  totalProducts Int

  businessHealth Float

  totalRevenueAtRisk Float

  totalProfitAtRisk Float

  totalBlockedCapital Float

  totalWorkingCapitalLocked Float

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  items InventorySnapshotItem[]

  @@index([organizationId])
  @@index([createdAt])
}

//////////////////////////////////////////////////////////
// INVENTORY SNAPSHOT ITEM
//////////////////////////////////////////////////////////

model InventorySnapshotItem {
  id String @id @default(uuid())

  snapshotId String

  sku String?

  productName String

  category String?

  quantity Float

  averageDailySales Float

  reorderLevel Float

  leadTimeDays Int

  daysUntilStockout Float

  inventoryHealth Float

  businessHealthScore Float

  revenueRisk Float

  profitRisk Float

  blockedCapital Float

  workingCapitalLocked Float

  recommendedAction String

  priority String

  createdAt DateTime @default(now())

  snapshot InventorySnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([productName])
}

//////////////////////////////////////////////////////////
// HEADER MAPPING MEMORY
//////////////////////////////////////////////////////////

model HeaderMapping {
  id String @id @default(cuid())

  originalHeader String
  mappedField    String

  confidence Float

  createdAt DateTime @default(now())
}
